# ─── Required for deploy ───────────────────────────────────────────────
# Hex-encoded private key of the deployer (without 0x is fine; with 0x also works).
# This account becomes the factory owner — keep it safe; transfer to a multisig
# before going to mainnet.
PRIVATE_KEY=

# Address that receives platform fees from every competition payout.
# In production, set to a multisig (Gnosis Safe).
FEE_RECIPIENT=

# ─── Optional ──────────────────────────────────────────────────────────
# Platform fee in basis points (500 = 5%). Capped at 1000 (10%) by the factory.
# Defaults to 500 if unset.
FEE_BPS=500

# ─── RPC endpoints (referenced by foundry.toml) ────────────────────────
# Get free RPCs from https://www.alchemy.com or https://www.infura.io.
# For quick tests, the public endpoints work too:
#   Base Sepolia public: https://sepolia.base.org
#   Base mainnet public: https://mainnet.base.org
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ─── Verification ──────────────────────────────────────────────────────
# Get a key from https://basescan.org/myapikey for source verification.
BASESCAN_API_KEY=

# ─── Reference: known USDC addresses (Circle native, NOT bridged) ──────
# Base mainnet:  0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Base Sepolia:  0x036CbD53842c5426634e7929541eC2318f3dCF7e
# These are passed to createEscrow per-competition, not stored at deploy time.
