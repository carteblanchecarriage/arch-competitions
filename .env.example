# ─── Privy ────────────────────────────────────────────────────────────
# Get your app id and secret from https://dashboard.privy.io → Settings → API keys
NEXT_PUBLIC_PRIVY_APP_ID=
# Server-only — never expose to client
PRIVY_APP_SECRET=

# ─── RPC endpoints ────────────────────────────────────────────────────
# Public endpoints work for development but rate-limit aggressively.
# For production, use a dedicated provider (Alchemy, Infura, QuickNode).
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ─── Deployed contract addresses ──────────────────────────────────────
# Populated after running the Foundry deploy script. See
# contracts/deployments/<chainId>.json after deploy.
NEXT_PUBLIC_FACTORY_ADDRESS_BASE=
NEXT_PUBLIC_FACTORY_ADDRESS_BASE_SEPOLIA=

# ─── Supabase ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — server-only, bypasses RLS. Keep out of client bundles.
# Needed for: npm run seed, npm run deploy:escrows, profile server actions.
SUPABASE_SERVICE_ROLE_KEY=
